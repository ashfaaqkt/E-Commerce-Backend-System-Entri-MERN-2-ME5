# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority

# Secret for JWT signing (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Google AI (Gemini) — chatbot & product insights
GEMINI_API_KEY=your_gemini_api_key_here

# Allowed browser origin(s) for CORS — use your Vercel URL in production.
# Multiple URLs: comma-separated (e.g. production + preview deploys)
FRONTEND_URL=http://localhost:5173

# Render sets PORT automatically; optional locally
PORT=5002
